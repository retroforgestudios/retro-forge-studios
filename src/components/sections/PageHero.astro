---
interface Props {
  eyebrow: string;
  heading: string;
  subhead?: string;
}
const { eyebrow, heading, subhead } = Astro.props;
---

<section class="relative flex h-[534px] w-full items-center overflow-hidden">
  <img
    src="/images/hero-forge.webp"
    alt="A blacksmith forging a glowing YouTube play button on an anvil stamped with the Retro Forge Studios logo"
    class="absolute inset-0 h-full w-full object-cover"
    width="2048"
    height="1152"
    loading="eager"
  />
  <div class="absolute inset-0 bg-charcoal/65"></div>

  <div class="relative mx-auto max-w-2xl px-4 text-center sm:px-6">
    <p class="text-marker text-lg text-amber">{eyebrow}</p>
    <h1 class="mt-1 text-3xl text-white sm:text-4xl">{heading}</h1>
    {subhead && <p class="mt-4 text-base text-gray-200">{subhead}</p>}
    <slot />
  </div>
</section>
