---
import { STATS } from "../../data/site";
---

<div class="mx-auto max-w-4xl">
  <p class="text-marker text-center text-lg text-amber">The numbers back it up:</p>
  <div class="mt-6 grid grid-cols-1 gap-8 sm:grid-cols-3">
    {STATS.map((stat) => (
      <div class="text-center">
        <p class="text-4xl text-red">{stat.value}</p>
        <p class="mt-2 text-sm text-gray-300">{stat.label}</p>
        <a href={stat.sourceUrl} target="_blank" rel="noopener noreferrer" class="mt-1 inline-block text-xs text-teal underline">
          via {stat.sourceLabel}
        </a>
      </div>
    ))}
  </div>
</div>
