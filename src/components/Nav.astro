---
import { NAV_LINKS, SERVICES, MENU_FEATURE, TOOLS } from "../data/site";
import MegaMenu from "./MegaMenu.astro";

const currentPath = new URL(Astro.request.url).pathname;

const serviceLinks = SERVICES.map((s) => ({
  href: `/services/${s.slug}`,
  label: s.name,
  description: s.teaser,
}));

const toolLinks = TOOLS.map((t) => ({
  href: t.href,
  label: t.name,
  description: t.teaser,
}));
---

<header class="sticky top-0 z-50 bg-charcoal/95 shadow-xl shadow-black/50 backdrop-blur">
  <nav class="mx-auto flex max-w-content items-center justify-between px-4 py-4 sm:px-6">
    <a href="/" class="flex items-center">
      <img src="/images/logo-wordmark.webp" alt="Retro Forge Studios" class="h-9 w-auto" width="480" height="120" fetchpriority="high" />
    </a>

    <ul class="hidden items-center gap-6 md:flex">
      {NAV_LINKS.map((link) => {
        if (link.href === "/services") {
          return (
            <MegaMenu
              label={link.label}
              href="/services"
              active={currentPath.startsWith("/services")}
              linksHeading="what i do"
              links={serviceLinks}
              feature={MENU_FEATURE}
            />
          );
        }

        if (link.href === "/tools") {
          return (
            <MegaMenu
              label={link.label}
              href="/tools"
              active={currentPath.startsWith("/tools") || toolLinks.some((t) => currentPath.startsWith(t.href))}
              linksHeading="free tools"
              links={toolLinks}
              columns={2}
            />
          );
        }

        return (
          <li>
            <a
              href={link.href}
              class:list={[
                "text-sm font-semibold transition-colors hover:text-teal",
                currentPath === link.href ? "text-teal" : "text-gray-200",
              ]}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>

    <a
      href="/contact"
      class="hidden rounded-md bg-red px-4 py-2 text-sm font-bold text-white transition duration-200 hover:bg-red/90 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-red/40 md:inline-flex"
    >
      Book a free call
    </a>

    <button
      id="nav-toggle"
      type="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      class="inline-flex items-center justify-center rounded-md p-2 text-white md:hidden"
    >
      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" />
      </svg>
    </button>
  </nav>

  <ul id="nav-mobile" class="hidden flex-col gap-1 border-t border-surface px-4 pb-4 md:hidden">
    {NAV_LINKS.map((link) => {
      if (link.href === "/services") {
        return (
          <li>
            <a href="/services" class="block px-3 pt-3 text-marker text-sm text-amber">Services</a>
            {serviceLinks.map((sub) => (
              <a
                href={sub.href}
                class:list={[
                  "block rounded-md py-2 pl-6 pr-3 text-sm font-semibold",
                  currentPath === sub.href ? "text-teal" : "text-gray-200",
                ]}
              >
                {sub.label}
              </a>
            ))}
          </li>
        );
      }

      if (link.href === "/tools") {
        return (
          <li>
            <a href="/tools" class="block px-3 pt-3 text-marker text-sm text-amber">Tools</a>
            {toolLinks.map((sub) => (
              <a
                href={sub.href}
                class:list={[
                  "block rounded-md py-2 pl-6 pr-3 text-sm font-semibold",
                  currentPath === sub.href ? "text-teal" : "text-gray-200",
                ]}
              >
                {sub.label}
              </a>
            ))}
          </li>
        );
      }

      return (
        <li>
          <a
            href={link.href}
            class:list={[
              "block rounded-md px-3 py-3 text-sm font-semibold",
              currentPath === link.href ? "text-teal" : "text-gray-200",
            ]}
          >
            {link.label}
          </a>
        </li>
      );
    })}
    <li>
      <a href="/contact" class="mt-2 block rounded-md bg-red px-3 py-3 text-center text-sm font-bold text-white transition duration-200 hover:bg-red/90">
        Book a free call
      </a>
    </li>
  </ul>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-mobile");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("flex");
    menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
  });
</script>
