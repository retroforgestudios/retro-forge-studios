---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = "", size = 160 } = Astro.props;

// Leaf positions along each laurel stem (distance up the stem, leaf tilt)
const leaves = [
  { t: 0.12, tilt: 38 },
  { t: 0.34, tilt: 30 },
  { t: 0.56, tilt: 22 },
  { t: 0.78, tilt: 14 },
];
---

<svg
  viewBox="0 0 200 200"
  width={size}
  height={size}
  class:list={["text-teal", className]}
  role="img"
  aria-label="Veteran Owned Business, Nebraska & Iowa, Established 2008"
>
  <defs>
    <path id="ring-path" d="M 100,100 m -78,0 a 78,78 0 1,1 156,0 a 78,78 0 1,1 -156,0" />
  </defs>

  <circle cx="100" cy="100" r="96" fill="#202020" stroke="currentColor" stroke-width="3" />
  <circle cx="100" cy="100" r="78" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 3" />

  <text fill="currentColor" font-size="10.5" font-family="Open Sans, sans-serif" font-weight="700" letter-spacing="2">
    <textPath href="#ring-path" startOffset="2%">
      VETERAN OWNED BUSINESS &#8226; NEBRASKA &amp; IOWA
    </textPath>
  </text>

  <!-- Laurel wreath flanking the shield -->
  <g fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
    <!-- left stem -->
    <path d="M62 134 Q48 104 60 74" />
    <!-- right stem (mirror) -->
    <path d="M138 134 Q152 104 140 74" />
  </g>
  <g fill="currentColor">
    {leaves.map(({ t, tilt }) => {
      const ly = 134 - t * 60;
      const lx = 56 + Math.sin(t * Math.PI) * 4;
      return <ellipse cx="0" cy="0" rx="6.5" ry="3" transform={`translate(${lx} ${ly}) rotate(${-tilt})`} />;
    })}
    {leaves.map(({ t, tilt }) => {
      const ly = 134 - t * 60;
      const lx = 144 - Math.sin(t * Math.PI) * 4;
      return <ellipse cx="0" cy="0" rx="6.5" ry="3" transform={`translate(${lx} ${ly}) rotate(${tilt})`} />;
    })}
  </g>

  <!-- Five-pointed star -->
  <path
    d="M100,57 L102.1,63.1 L108.6,63.2 L103.4,67.1 L105.3,73.3 L100,69.6 L94.7,73.3 L96.6,67.1 L91.4,63.2 L97.9,63.1 Z"
    fill="currentColor"
  />

  <!-- Shield with checkmark -->
  <g transform="translate(100 96)">
    <path
      d="M0 -28 L24 -19 V4 C24 24 11 35 0 40 C-11 35 -24 24 -24 4 V-19 Z"
      fill="#202020"
      stroke="currentColor"
      stroke-width="3"
    />
    <path d="M-9 0 L-1 9 L12 -9" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
  </g>

  <!-- Ribbon banner -->
  <g transform="translate(100 158)">
    <path d="M-46 -10 L46 -10 L46 10 L0 4 L-46 10 Z" fill="currentColor" opacity="0.15" />
    <path d="M-46 -10 L-58 0 L-46 10 Z" fill="currentColor" />
    <path d="M46 -10 L58 0 L46 10 Z" fill="currentColor" />
    <text x="0" y="5" text-anchor="middle" fill="currentColor" font-family="Carter One, sans-serif" font-size="13">
      EST. 2008
    </text>
  </g>
</svg>
