---
interface Props {
  class?: string;
  size?: number;
}
const { class: className = "", size = 160 } = Astro.props;

// Leaf positions along each laurel stem (distance up the stem, leaf tilt)
const leaves = [
  { t: 0.12, tilt: 38 },
  { t: 0.34, tilt: 30 },
  { t: 0.56, tilt: 22 },
  { t: 0.78, tilt: 14 },
];
---

<svg
  viewBox="0 0 200 200"
  width={size}
  height={size}
  class:list={["text-teal", className]}
  role="img"
  aria-label="Veteran Owned Business, Nebraska & Iowa, Established 2008"
>
  <defs>
    <!-- top arc: drawn left -> right over the top, text reads upright -->
    <path id="seal-top" d="M 16,100 A 84,84 0 0 1 184,100" />
    <!-- bottom arc: drawn left -> right under the bottom, text reads upright -->
    <path id="seal-bottom" d="M 18,108 A 84,84 0 0 0 182,108" />
  </defs>

  <circle cx="100" cy="100" r="96" fill="#202020" stroke="currentColor" stroke-width="3" />

  <text fill="currentColor" font-size="11" font-family="Open Sans, sans-serif" font-weight="700" letter-spacing="1.5">
    <textPath href="#seal-top" startOffset="50%" text-anchor="middle">
      VETERAN OWNED BUSINESS
    </textPath>
  </text>
  <text fill="currentColor" font-size="11" font-family="Open Sans, sans-serif" font-weight="700" letter-spacing="1.5">
    <textPath href="#seal-bottom" startOffset="50%" text-anchor="middle">
      NEBRASKA &amp; IOWA
    </textPath>
  </text>

  <!-- dashed border just inside the text band -->
  <circle cx="100" cy="100" r="72" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 3" />

  <!-- side separators at 9 & 3 o'clock -->
  <circle cx="20" cy="100" r="2" fill="currentColor" />
  <circle cx="180" cy="100" r="2" fill="currentColor" />

  <!-- Laurel wreath flanking the shield -->
  <g fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
    <path d="M62 128 Q48 100 60 72" />
    <path d="M138 128 Q152 100 140 72" />
  </g>
  <g fill="currentColor">
    {leaves.map(({ t, tilt }) => {
      const ly = 128 - t * 56;
      const lx = 56 + Math.sin(t * Math.PI) * 4;
      return <ellipse cx="0" cy="0" rx="6.5" ry="3" transform={`translate(${lx} ${ly}) rotate(${-tilt})`} />;
    })}
    {leaves.map(({ t, tilt }) => {
      const ly = 128 - t * 56;
      const lx = 144 - Math.sin(t * Math.PI) * 4;
      return <ellipse cx="0" cy="0" rx="6.5" ry="3" transform={`translate(${lx} ${ly}) rotate(${tilt})`} />;
    })}
  </g>

  <!-- Five-pointed star -->
  <path
    d="M100,50 L102.1,56.1 L108.6,56.2 L103.4,60.1 L105.3,66.3 L100,62.6 L94.7,66.3 L96.6,60.1 L91.4,56.2 L97.9,56.1 Z"
    fill="currentColor"
  />

  <!-- Shield with checkmark (amber embellishment) -->
  <g transform="translate(100 90)">
    <path
      d="M0 -24 L21 -16 V4 C21 21 9.5 30 0 34 C-9.5 30 -21 21 -21 4 V-16 Z"
      fill="#202020"
      stroke="currentColor"
      stroke-width="3"
    />
    <!-- amber inner accent line -->
    <path
      d="M0 -19 L16 -12.5 V3 C16 17 7 25 0 28.5 C-7 25 -16 17 -16 3 V-12.5 Z"
      fill="none"
      stroke="#ef9c2f"
      stroke-width="1.4"
    />
    <path d="M-8 0 L-1 8 L11 -8" fill="none" stroke="#ef9c2f" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
  </g>

  <!-- EST. 2008 -->
  <text x="100" y="142" text-anchor="middle" fill="currentColor" font-family="Carter One, sans-serif" font-size="13">
    EST. 2008
  </text>
</svg>
