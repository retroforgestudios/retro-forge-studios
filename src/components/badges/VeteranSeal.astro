---
// TODO(open-item): replace with final logo-team artwork if/when supplied — this is a built-from-spec placeholder.
interface Props {
  class?: string;
  size?: number;
}
const { class: className = "", size = 160 } = Astro.props;
---

<svg
  viewBox="0 0 200 200"
  width={size}
  height={size}
  class:list={["text-teal", className]}
  role="img"
  aria-label="Veteran Owned Business, Nebraska & Iowa, Established 2008"
>
  <defs>
    <path id="ring-path" d="M 100,100 m -78,0 a 78,78 0 1,1 156,0 a 78,78 0 1,1 -156,0" />
  </defs>

  <circle cx="100" cy="100" r="96" fill="#202020" stroke="currentColor" stroke-width="3" />
  <circle cx="100" cy="100" r="78" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 3" />

  <text fill="currentColor" font-size="10.5" font-family="Open Sans, sans-serif" font-weight="700" letter-spacing="2">
    <textPath href="#ring-path" startOffset="2%">
      VETERAN OWNED BUSINESS &#8226; NEBRASKA &amp; IOWA
    </textPath>
  </text>

  <g transform="translate(100 92)">
    <path
      d="M0 -32 L26 -22 V4 C26 26 12 38 0 44 C-12 38 -26 26 -26 4 V-22 Z"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
    />
    <path d="M-10 0 L-2 10 L13 -10" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
  </g>

  <text x="100" y="158" text-anchor="middle" fill="currentColor" font-family="Carter One, sans-serif" font-size="14">
    EST. 2008
  </text>
</svg>
