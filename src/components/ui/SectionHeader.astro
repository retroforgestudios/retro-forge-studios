---
interface Props {
  eyebrow: string;
  heading: string;
  subhead?: string;
  align?: "left" | "center";
  class?: string;
}
const { eyebrow, heading, subhead, align = "center", class: className = "" } = Astro.props;
---

<div class:list={["max-w-2xl", align === "center" ? "mx-auto text-center" : "text-left", className]}>
  <p class="text-marker text-amber text-lg">{eyebrow}</p>
  <h2 class="mt-1 text-3xl sm:text-4xl text-white">{heading}</h2>
  {subhead && <p class="mt-4 text-base text-gray-300">{subhead}</p>}
</div>
