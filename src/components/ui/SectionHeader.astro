---
interface Props {
  eyebrow: string;
  heading: string;
  subhead?: string;
  align?: "left" | "center";
  onLight?: boolean;
  class?: string;
}
const { eyebrow, heading, subhead, align = "center", onLight = false, class: className = "" } = Astro.props;
---

<div class:list={["max-w-2xl", align === "center" ? "mx-auto text-center" : "text-left", className]}>
  <p class:list={["text-marker text-lg", onLight ? "text-amber-deep" : "text-amber"]}>{eyebrow}</p>
  <h2 class:list={["mt-1 text-3xl sm:text-4xl", onLight ? "text-gray-900" : "text-white"]}>{heading}</h2>
  {subhead && <p class:list={["mt-4 text-base", onLight ? "text-gray-700" : "text-gray-300"]}>{subhead}</p>}
</div>
