---
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = "" } = Astro.props;

const LOGOS: Record<string, string> = {
  HubSpot: "/images/brands/hubspot.webp",
  Claude: "/images/brands/claude.webp",
  YouTube: "/images/brands/youtube.webp",
  WordPress: "/images/brands/wordpress.webp",
  Gemini: "/images/brands/gemini.webp",
  TikTok: "/images/brands/tiktok.webp",
  GitHub: "/images/brands/github.webp",
  "Node.js": "/images/brands/nodejs.webp",
  React: "/images/brands/react.webp",
  Cloudflare: "/images/brands/cloudflare.webp",
};

const src = LOGOS[name];
---

{src && <img src={src} alt={name} class:list={["w-auto", className || "h-7"]} width="800" height="200" loading="lazy" />}
