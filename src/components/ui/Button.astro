---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  class?: string;
  target?: string;
}
const { href, variant = "primary", class: className = "", target } = Astro.props;

const base =
  "inline-flex items-center justify-center rounded-md px-6 py-3 font-bold transition duration-200 w-full sm:w-auto text-center";
const variants = {
  primary: "bg-red text-white hover:bg-red/90 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-red/40",
  secondary: "bg-transparent text-teal border border-teal hover:bg-teal/10 hover:-translate-y-0.5",
};
---

<a
  href={href}
  class:list={[base, variants[variant], className]}
  target={target}
  rel={target === "_blank" ? "noopener noreferrer" : undefined}
>
  <slot />
</a>
