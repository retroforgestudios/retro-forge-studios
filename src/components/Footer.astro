---
import { NAV_LINKS, SITE, SOCIAL_LINKS } from "../data/site";
import VeteranSeal from "./badges/VeteranSeal.astro";
---

<footer class="border-t border-surface bg-charcoal">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-3">
    <div>
      <p class="text-xl text-white" style="font-family: var(--font-display);">retro forge studios</p>
      <p class="mt-3 max-w-xs text-sm text-gray-400">
        AI-enhanced content, brand strategy, and social media management for Nebraska & Iowa small businesses.
      </p>
      <VeteranSeal size={110} class="mt-6" />
    </div>

    <div>
      <p class="text-marker text-amber">site</p>
      <ul class="mt-3 space-y-2">
        {NAV_LINKS.map((link) => (
          <li><a href={link.href} class="text-sm text-gray-300 hover:text-teal">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-marker text-amber">get in touch</p>
      <p class="mt-3 text-sm text-gray-300">
        <a href={`mailto:${SITE.email}`} class="hover:text-teal">{SITE.email}</a>
      </p>
      <div class="mt-4 flex gap-4">
        {SOCIAL_LINKS.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label} class="text-gray-300 hover:text-teal">
            {social.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="border-t border-surface px-4 py-6 text-center text-xs text-gray-500">
    &copy; {new Date().getFullYear()} Retro Forge Studios. All rights reserved.
  </div>
</footer>
