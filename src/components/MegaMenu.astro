---
interface MenuLink {
  href: string;
  label: string;
  description?: string;
}
interface Feature {
  eyebrow: string;
  title: string;
  text: string;
  image: string;
  ctaLabel: string;
  href: string;
  secondary?: { label: string; href: string };
}
interface Props {
  label: string;
  href: string;
  active?: boolean;
  linksHeading?: string;
  links: MenuLink[];
  feature: Feature;
}
const { label, href, active = false, linksHeading, links, feature } = Astro.props;
---

<li class="group relative">
  <a
    href={href}
    class:list={[
      "inline-flex items-center gap-1 text-sm font-semibold transition-colors hover:text-teal",
      active ? "text-teal" : "text-gray-200",
    ]}
  >
    {label}
    <svg viewBox="0 0 24 24" class="h-4 w-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>

  <div class="invisible absolute left-0 top-full z-50 w-[640px] max-w-[90vw] pt-3 opacity-0 transition duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
    <div class="grid grid-cols-1 gap-6 rounded-xl border border-surface bg-[#1f2125] p-6 shadow-2xl sm:grid-cols-[1fr_240px]">
      <div class="space-y-1">
        {linksHeading && (
          <p class="text-marker px-3 pb-2 text-sm text-amber">{linksHeading}</p>
        )}
        {links.map((l) => (
          <a href={l.href} class="block rounded-md p-3 transition-colors hover:bg-white/5">
            <p class="font-semibold text-white">{l.label}</p>
            {l.description && <p class="mt-0.5 text-sm text-gray-400">{l.description}</p>}
          </a>
        ))}
      </div>

      <div class="flex flex-col overflow-hidden rounded-lg border border-surface bg-charcoal">
        <div class="p-3">
          <img src={feature.image} alt={feature.title} class="aspect-[8/5] w-full rounded-md object-cover" width="240" height="150" />
        </div>
        <div class="flex flex-1 flex-col p-4">
          <p class="text-marker text-xs text-amber">{feature.eyebrow}</p>
          <p class="mt-1 font-semibold text-white">{feature.title}</p>
          <p class="mt-1 text-sm text-gray-400">{feature.text}</p>
          <a
            href={feature.href}
            class="mt-4 inline-flex items-center justify-center rounded-md bg-red px-4 py-2 text-sm font-bold text-white transition duration-200 hover:bg-red/90"
          >
            {feature.ctaLabel}
          </a>
          {feature.secondary && (
            <a href={feature.secondary.href} class="mt-3 text-center text-xs font-semibold text-gray-400 transition-colors hover:text-teal">
              {feature.secondary.label} &rarr;
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</li>
