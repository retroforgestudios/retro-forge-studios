---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/sections/PageHero.astro";
import CTABanner from "../../components/sections/CTABanner.astro";
import { SERVICES } from "../../data/site";

export function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const others = SERVICES.filter((s) => s.slug !== service.slug);
---

<BaseLayout title={service.name} description={service.teaser}>
  <PageHero eyebrow="what i do" heading={service.name} subhead={service.teaser} />

  <section class="px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl">
      <a href="/services" class="text-sm font-semibold text-teal-deep hover:underline">&larr; All services</a>

      <div class="mt-6 rounded-2xl border border-surface bg-[#1f2125] p-8 sm:p-10">
        <div class="flex items-center gap-4">
          <div class="flex h-12 w-12 flex-none items-center justify-center rounded-full bg-charcoal text-amber">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
              <path d={service.icon} />
            </svg>
          </div>
          <h2 class="text-2xl text-white sm:text-3xl">{service.heading}</h2>
        </div>

        <div class="mt-8 grid gap-8 sm:grid-cols-2">
          <div>
            <p class="text-marker text-sm text-amber">included</p>
            <ul class="mt-3 space-y-2">
              {service.included.map((item) => (
                <li class="flex gap-2 text-sm text-gray-300">
                  <span class="text-teal">&#8226;</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="space-y-4">
            {service.statCallout && (
              <p class="rounded-md border border-amber/30 bg-amber/10 p-4 text-sm text-amber">
                {service.statCallout}
              </p>
            )}
            <p class="text-sm text-gray-400">
              <span class="font-semibold text-white">Who it's for: </span>
              {service.who}
            </p>
            <p class="text-sm text-gray-400">
              <span class="font-semibold text-white">Outcome: </span>
              {service.outcome}
            </p>
          </div>
        </div>
      </div>

      <div class="mt-12 border-t border-gray-300 pt-8">
        <p class="text-marker text-amber-deep">other services</p>
        <div class="mt-3 flex flex-wrap gap-3">
          {others.map((s) => (
            <a
              href={`/services/${s.slug}`}
              class="rounded-full border border-surface px-4 py-2 text-sm font-semibold text-gray-700 transition-colors hover:border-teal-deep hover:text-teal-deep"
            >
              {s.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Ready to get started?"
    subtext="Let's talk through your goals and figure out the right mix — no pressure, no jargon."
    buttonLabel="Book a free call"
  />
</BaseLayout>
