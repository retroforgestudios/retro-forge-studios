---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import CTABanner from "../components/sections/CTABanner.astro";
import PageHero from "../components/sections/PageHero.astro";
import { PROCESS_STEPS } from "../data/site";

const toolkit = [
  "Rapid drafting and ideation, so projects move in days, not weeks",
  "AI-assisted keyword research and SEO optimization",
  "Trend and analytics monitoring to catch what's working before it's old news",
  "Every output reviewed and shaped by an actual person before you see it",
];

const expectations = [
  {
    name: "Turnaround time",
    description:
      "Project timelines vary depending on scope — we'll map out a realistic timeline together during the discovery call.",
    icon: "M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0z",
  },
  {
    name: "Communication style",
    description:
      "Email for everything important, plus a shared doc or calendar to track ongoing projects — no chasing updates across five different apps.",
    icon: "M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z",
  },
  {
    name: "Contract terms",
    description: "Month-to-month. No long-term lock-in — if it's not working for you, you can walk away anytime.",
    icon: "M9 12h6m-6 4h6M9 8h2M7 4h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z",
  },
  {
    name: "How success gets measured",
    description: "Tied to your goals, not generic platform metrics.",
    icon: "M3 3v18h18M7 14l4-4 3 3 5-6",
  },
];
---

<BaseLayout
  title="How I Work"
  description="No mystery, no jargon — here's exactly how a Retro Forge Studios project runs from first call to delivery."
>
  <PageHero
    eyebrow="how i work"
    heading="No mystery, no jargon — here's exactly how this works."
    subhead="You're trusting someone with your business's voice and visibility. Here's exactly what that looks like, step by step — no vague promises."
  />

  <section class="bg-band px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl text-gray-900">New studio. Decade-plus of real experience.</h2>
      <p class="mt-6 text-gray-700">
        Retro Forge Studios is new — but I'm not. I'm a retired Air Force veteran who's spent over a decade growing
        brand presence across gaming, retail, and consumer electronics — including accounts for multimillion-dollar brands. As a
        veteran-owned local studio, you get that same caliber of strategy without the agency overhead — and you work
        directly with me the whole way, with my full attention.
      </p>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6">
    <SectionHeader onLight eyebrow="step by step" heading="The process" />
    <div class="mx-auto mt-10 grid max-w-content grid-cols-1 gap-6 sm:grid-cols-2">
      {PROCESS_STEPS.map((step, i) => (
        <div class="rounded-lg border border-surface bg-[#2c2f34] p-6">
          <p class="text-marker text-amber">{`0${i + 1}`}</p>
          <h3 class="mt-1 text-xl text-white">{step.name}</h3>
          <p class="mt-2 text-sm text-gray-300">{step.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-band px-4 py-16 sm:px-6">
    <SectionHeader onLight eyebrow="the toolkit" heading="AI is the speed. I'm still the voice." />
    <div class="mx-auto mt-10 grid max-w-4xl items-center gap-10 sm:grid-cols-2">
      <ul class="space-y-3">
        {toolkit.map((item) => (
          <li class="flex gap-3 text-gray-700">
            <span class="text-teal-deep">&#8226;</span>
            {item}
          </li>
        ))}
      </ul>
      <img
        src="/images/workflow-engagement-graphic.webp"
        alt="Workflow time savings and engagement lift metrics from AI-assisted content work"
        class="mx-auto w-full max-w-sm rounded-xl"
        width="1000"
        height="1000"
        loading="lazy"
      />
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl">
      <SectionHeader onLight eyebrow="set expectations" heading="What you can expect" />
      <div class="mx-auto mt-10 max-w-2xl space-y-8">
        {expectations.map((item) => (
          <div class="flex gap-6">
            <div class="flex h-14 w-14 flex-none items-center justify-center rounded-full bg-amber text-charcoal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7">
                <path d={item.icon} />
              </svg>
            </div>
            <div>
              <h3 class="text-xl text-gray-900">{item.name}</h3>
              <p class="mt-1 text-gray-700">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Curious if this is the right fit?"
    subtext="No sales script, no pressure — just a conversation about your business."
    buttonLabel="Book a free call"
  />
</BaseLayout>
