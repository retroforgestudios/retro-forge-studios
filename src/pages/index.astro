---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import ServiceCard from "../components/sections/ServiceCard.astro";
import StatsBar from "../components/sections/StatsBar.astro";
import CTABanner from "../components/sections/CTABanner.astro";
import LeadMagnetCTA from "../components/sections/LeadMagnetCTA.astro";
import ToolMarquee from "../components/sections/ToolMarquee.astro";
import VeteranPill from "../components/badges/VeteranPill.astro";
import { getCollection } from "astro:content";
import { HERO_HEADLINE, SERVICES, SITE } from "../data/site";

const latestPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Home"
  description={`AI-enhanced content, social, and brand strategy for Nebraska & Iowa business owners — based in ${SITE.city}, ${SITE.region}, moving at the speed your business needs.`}
>
  <!-- Hero -->
  <section class="relative flex h-[534px] w-full items-center overflow-hidden">
    <img
      src="/images/hero-forge.webp"
      alt="A blacksmith forging a glowing YouTube play button on an anvil stamped with the Retro Forge Studios logo"
      class="absolute inset-0 h-full w-full object-cover"
      width="2048"
      height="1152"
      loading="eager"
    />
    <div class="absolute inset-0 bg-charcoal/65"></div>

    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6">
      <p class="text-marker text-lg text-amber">forged for local business</p>
      <h1 class="mt-2 text-4xl text-white sm:text-6xl">{HERO_HEADLINE}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-200">
        AI-enhanced content, social, and brand strategy — moving at the speed your business needs, without the
        big-agency price tag or red tape.
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button href="/contact">Book a free call</Button>
        <a href="/how-i-work" class="font-semibold text-teal hover:underline">See how I work &rarr;</a>
      </div>

      <div class="mt-8 flex items-center justify-center gap-3">
        <VeteranPill />
        <span class="text-marker text-sm text-amber">forged for local business</span>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="border-y border-surface bg-band py-8">
    <div class="mx-auto max-w-content px-4 text-center sm:px-6">
      <p class="text-sm text-gray-700">
        The tools I use every day to get results — built by a veteran who calls Nebraska home.
      </p>
      <ToolMarquee />
      <p class="mt-4 text-xs text-gray-500">
        Product names and logos are trademarks of their respective owners. Not an official partner or endorsement.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="px-4 py-20 sm:px-6">
    <SectionHeader onLight eyebrow="what i do" heading="Four ways I help your business grow" />
    <div class="mx-auto mt-12 grid max-w-content grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {SERVICES.map((service) => (
        <ServiceCard name={service.name} teaser={service.teaser} href={`/services/${service.slug}`} />
      ))}
    </div>
  </section>

  <!-- Differentiator -->
  <section class="bg-band px-4 py-20 sm:px-6">
    <div class="mx-auto grid max-w-4xl items-center gap-10 sm:grid-cols-2">
      <img
        src="/images/work-laptop-purple.webp"
        alt="A business owner working on a laptop"
        class="mx-auto w-full max-w-sm rounded-xl"
        width="1000"
        height="1000"
        loading="lazy"
      />
      <div>
        <h2 class="text-3xl text-gray-900 sm:text-4xl">Why a local studio instead of a big agency?</h2>
        <p class="mt-6 text-gray-700">
          Many agencies lock you into a long contract and hand you off to a junior account manager. I don't — you work
          directly with me. And I know the Nebraska and Iowa market because I live in it. You get agency-level strategy
          and AI-powered speed, with the kind of personal attention a small business actually needs.
        </p>
      </div>
    </div>
  </section>

  <!-- How I Work teaser -->
  <section class="bg-surface px-4 py-16 text-center sm:px-6">
    <h2 class="text-3xl text-white">Curious what working together actually looks like?</h2>
    <p class="mx-auto mt-4 max-w-xl text-gray-200">
      No mystery, no jargon — here's exactly how a project runs from first call to delivery.
    </p>
    <a href="/how-i-work" class="mt-6 inline-block font-semibold text-teal hover:underline">See how I work &rarr;</a>
  </section>

  <!-- Lead magnet -->
  <LeadMagnetCTA variant="band" />

  <!-- Stats bar -->
  <section class="px-4 py-20 sm:px-6">
    <StatsBar onLight />
  </section>

  <!-- Blog teaser -->
  <section class="px-4 py-20 sm:px-6">
    <SectionHeader onLight eyebrow="the blog" heading="Tips to grow your business" />
    <div class="mx-auto mt-12 grid max-w-content grid-cols-1 gap-6 sm:grid-cols-3">
      {latestPosts.map((post) => (
        <a
          href={`/blog/${post.id}/`}
          class="group flex flex-col overflow-hidden rounded-lg border border-surface bg-[#1f2125] transition-colors hover:border-teal"
        >
          {post.data.image && (
            <div class="aspect-video overflow-hidden">
              <img
                src={post.data.image}
                alt={post.data.title}
                loading="lazy"
                class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
              />
            </div>
          )}
          <div class="flex flex-1 flex-col p-6">
            <p class="text-marker text-sm text-amber">
              {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </p>
            <h3 class="mt-1 text-lg text-white">{post.data.title}</h3>
            <p class="mt-2 flex-1 text-sm text-gray-300">{post.data.description}</p>
            <span class="mt-4 font-semibold text-teal">Read more &rarr;</span>
          </div>
        </a>
      ))}
    </div>
    <p class="mt-10 text-center">
      <a href="/blog" class="font-semibold text-teal-deep hover:underline">Read the blog &rarr;</a>
    </p>
  </section>

  <!-- Closing CTA -->
  <CTABanner
    heading="Ready to grow your business?"
    subtext="Let's talk about what's actually going to move the needle for you — no pressure, no sales pitch."
    buttonLabel="Book your free consultation"
  />
</BaseLayout>
