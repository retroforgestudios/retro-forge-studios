---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";
---

<BaseLayout
  title="Free Website Audit"
  description="Run a free, instant audit of any website — HTTPS, mobile-friendliness, SEO basics, and more."
>
  <section class="bg-charcoal px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-2xl">
      <div class="rounded-2xl border border-surface bg-[#1f2125] p-8 shadow-2xl sm:p-10">
        <div class="text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-teal/40 bg-teal/10 px-4 py-1 text-xs font-bold uppercase tracking-wide text-teal">
            <span class="h-1.5 w-1.5 rounded-full bg-teal"></span> Website Audit
          </span>
          <h1 class="mt-4 text-3xl text-white sm:text-4xl">Check your website's health</h1>
          <p class="mx-auto mt-3 max-w-md text-gray-300">
            How's your site really doing? Run a free audit and find out in seconds — no email required.
          </p>
        </div>

        <form id="audit-form" class="mt-8">
          <div class="flex items-center gap-2 rounded-lg border border-surface bg-charcoal px-4 py-3">
            <svg viewBox="0 0 24 24" class="h-5 w-5 flex-none text-teal" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M3 12h18M12 3c2.5 2.5 3.5 5.5 3.5 9s-1 6.5-3.5 9c-2.5-2.5-3.5-5.5-3.5-9s1-6.5 3.5-9z" />
            </svg>
            <input
              id="audit-url"
              type="text"
              placeholder="Enter your website — e.g. yourbusiness.com"
              class="flex-1 bg-transparent text-white placeholder:text-gray-500 focus:outline-none"
              autocomplete="off"
              required
            />
            <span class="flex-none rounded-md bg-surface px-2 py-1 text-xs font-bold text-gray-400">URL</span>
          </div>

          <button
            id="audit-submit"
            type="submit"
            class="mt-4 w-full rounded-md bg-red px-6 py-3 text-center font-bold text-white transition duration-200 hover:bg-red/90 disabled:opacity-60"
          >
            Run Audit
          </button>
        </form>

        <div id="audit-error" hidden class="mt-4 rounded-md border border-red/40 bg-red/10 px-4 py-3 text-sm text-red"></div>

        <div id="audit-results" hidden class="mt-8 border-t border-surface pt-8">
          <div class="flex items-center gap-4">
            <div id="audit-score-ring" class="flex h-20 w-20 flex-none items-center justify-center rounded-full border-4 border-teal">
              <span id="audit-score" class="text-xl font-bold text-white"></span>
            </div>
            <div class="flex-1">
              <p class="text-marker text-lg text-amber">Grade: <span id="audit-grade"></span></p>
              <p class="text-sm text-gray-400"><span id="audit-count"></span> checks passed</p>
            </div>
            <button
              id="audit-download"
              type="button"
              class="flex-none rounded-md border border-teal px-4 py-2 text-sm font-semibold text-teal transition-colors hover:bg-teal/10"
            >
              Download My Results
            </button>
          </div>

          <ul id="audit-checklist" class="mt-6 space-y-4"></ul>

          <div class="mt-8 rounded-lg border border-teal/30 bg-teal/5 p-5">
            <p id="audit-summary-text" class="text-sm leading-relaxed text-gray-200"></p>
            <a href="/contact" class="mt-3 inline-block text-sm font-semibold text-teal hover:underline">
              Get in touch to fix this &rarr;
            </a>
          </div>

          <div class="mt-6 rounded-xl bg-amber p-6 text-center">
            <p class="font-semibold text-charcoal">Want these fixed?</p>
            <p class="mt-1 text-sm text-charcoal/80">
              I build fast, custom websites that pass every one of these checks out of the box.
            </p>
            <a
              href="/services/website-design"
              class="mt-4 inline-block rounded-md bg-red px-6 py-3 font-bold text-white transition duration-200 hover:bg-red/90"
            >
              See Website Design &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ contactEmail: SITE.email }}>
    window.__RFS_CONTACT_EMAIL = contactEmail;
  </script>

  <script>
    import { jsPDF } from "jspdf";

    const CONTACT_EMAIL = (window as unknown as { __RFS_CONTACT_EMAIL: string }).__RFS_CONTACT_EMAIL;

    const form = document.getElementById("audit-form") as HTMLFormElement;
    const urlInput = document.getElementById("audit-url") as HTMLInputElement;
    const submitBtn = document.getElementById("audit-submit") as HTMLButtonElement;
    const errorBox = document.getElementById("audit-error") as HTMLDivElement;
    const results = document.getElementById("audit-results") as HTMLDivElement;
    const scoreEl = document.getElementById("audit-score") as HTMLSpanElement;
    const scoreRing = document.getElementById("audit-score-ring") as HTMLDivElement;
    const gradeEl = document.getElementById("audit-grade") as HTMLSpanElement;
    const countEl = document.getElementById("audit-count") as HTMLSpanElement;
    const checklist = document.getElementById("audit-checklist") as HTMLUListElement;
    const summaryText = document.getElementById("audit-summary-text") as HTMLParagraphElement;
    const downloadBtn = document.getElementById("audit-download") as HTMLButtonElement;

    type CheckResult = { key: string; label: string; pass: boolean; detail: string };
    type AuditData = { url: string; score: number; grade: string; checks: CheckResult[] };

    let lastAudit: AuditData | null = null;

    // One-line, actionable fix per check — shown in the PDF under any failed
    // check so the report explains not just what's wrong, but what to do
    // about it. Keyed by the check's stable `key`, not its label.
    const RECOMMENDATIONS: Record<string, string> = {
      https: "Install an SSL certificate (many hosts offer this free) and redirect all HTTP traffic to HTTPS.",
      speed: "Move to a faster host or CDN, or reduce what the server does before it responds to a request.",
      title: "Add a clear, keyword-relevant <title> tag between 10 and 65 characters — one of the biggest on-page SEO signals.",
      description: "Write a meta description between 50 and 160 characters summarizing the page — it's often what shows up in search results.",
      mobile: "Add a responsive viewport meta tag and confirm the layout adapts cleanly to phone-sized screens.",
      indexable: "Remove the noindex tag unless this page is meant to be hidden — otherwise it can't appear in search results at all.",
      canonical: "Add a canonical tag pointing to the preferred version of this URL to avoid duplicate-content issues.",
      h1: "Make sure the page has exactly one <h1> that clearly states its main topic.",
      "alt-text": "Add descriptive alt text to meaningful images — it helps accessibility and can drive image-search traffic.",
      lang: "Add a lang attribute to the <html> tag (e.g. lang=\"en\") — a quick, easy accessibility fix.",
      favicon: "Add a favicon so the site looks finished in browser tabs and bookmarks.",
      compression: "Enable gzip or Brotli compression on the server or CDN to shrink page size and speed up loads.",
      "mixed-content": "Update any plain-HTTP resource links to HTTPS so browsers stop blocking or flagging them.",
      schema: "Add structured data (schema.org JSON-LD) so Google can better understand and showcase the business.",
      social: "Add Open Graph tags (og:title, og:image, etc.) so shared links look right on social media.",
      robots: "Add a robots.txt file at the site root to guide search engine crawlers.",
      sitemap: "Reference a sitemap.xml file inside robots.txt so search engines can find every page.",
      "real-user-speed": "Compress images, defer non-critical scripts, and trim what has to load before the page is usable.",
      lcp: "Optimize the largest visible image or text block and cut render-blocking resources so content appears sooner.",
      cls: "Reserve space for images, embeds, and ads up front so content doesn't jump around as the page loads.",
      tbt: "Reduce heavy JavaScript that runs right after load and blocks the page from responding to taps and clicks.",
      "real-a11y": "Fix the flagged accessibility issues — common culprits are color contrast, missing labels, and ARIA errors.",
      "real-best-practices": "Address the flagged issues — often outdated libraries, browser console errors, or insecure patterns.",
    };

    // What category each check falls under, and the actual mechanism by
    // which failing it hurts the site — not just "this is bad," but why:
    // whether it's a direct Google ranking factor, a browser-enforced
    // penalty, an accessibility/legal exposure, or a trust signal.
    const WHY_IT_MATTERS: Record<string, { category: string; why: string }> = {
      https: {
        category: "Security & Trust",
        why: "Browsers mark non-HTTPS pages \"Not Secure\" right in the address bar, and Google has confirmed HTTPS is a direct ranking signal — this can suppress rankings and scare off visitors before they read a word.",
      },
      speed: {
        category: "Performance",
        why: "Server response time is the floor every other load metric is built on — a slow server delays everything downstream, and Google factors real-world speed into ranking.",
      },
      title: {
        category: "SEO",
        why: "The title tag is one of the single strongest on-page ranking signals, and it's the clickable headline shown in search results — a missing or bad one directly suppresses both ranking and click-through rate.",
      },
      description: {
        category: "SEO",
        why: "Not a direct ranking factor, but it's usually the snippet text shown under the title in search results — a missing one lets Google auto-generate something generic, which quietly lowers click-through rate.",
      },
      mobile: {
        category: "Mobile & SEO",
        why: "Google indexes the mobile version of a site first, so a page that doesn't render properly on phones can be ranked worse — on top of frustrating the majority of visitors, who are on mobile.",
      },
      indexable: {
        category: "SEO — Critical",
        why: "A noindex tag tells Google not to show this page in search results at all — this is the most severe possible SEO issue since the page becomes invisible to search, regardless of everything else.",
      },
      canonical: {
        category: "SEO",
        why: "Without a canonical tag, Google can treat www vs. non-www or trailing-slash variants as separate duplicate pages, splitting ranking signals across them instead of consolidating into one.",
      },
      h1: {
        category: "SEO & Accessibility",
        why: "The H1 is the strongest heading-level signal for what a page is about — zero H1s leaves that signal blank, and multiple H1s dilute it, in both cases making it harder for Google and screen readers to identify the main topic.",
      },
      "alt-text": {
        category: "Accessibility & SEO",
        why: "Screen readers rely on alt text to describe images to visitors who can't see them — without it, that content is simply skipped. It's also indexed for Google Image Search, so missing alt text is a lost traffic channel too.",
      },
      lang: {
        category: "Accessibility",
        why: "Screen readers use the lang attribute to choose the correct pronunciation and voice — without it, assistive tech can mispronounce every word on the page.",
      },
      favicon: {
        category: "Trust & Polish",
        why: "It's a small detail, but a blank browser tab icon is a visible, immediate signal of an unfinished or unmaintained site — the kind of thing that quietly erodes trust before a visitor reads any content.",
      },
      compression: {
        category: "Performance",
        why: "Uncompressed responses can be 60-80% larger than they need to be — every visitor downloads more bytes than necessary, which disproportionately hurts anyone on a slower mobile connection.",
      },
      "mixed-content": {
        category: "Security",
        why: "Browsers actively block or flag insecure HTTP resources loaded on an HTTPS page — this can silently break images, scripts, or styles, or trigger a security warning that scares visitors off.",
      },
      schema: {
        category: "SEO",
        why: "Structured data is what unlocks rich results — star ratings, business hours, breadcrumbs — directly in the search listing. Without it, the listing looks plainer next to competitors who have it.",
      },
      social: {
        category: "Marketing & Trust",
        why: "Without Open Graph tags, links shared on Facebook, LinkedIn, or iMessage show no image and a generic title — a broken-looking preview that measurably lowers click-through from social shares.",
      },
      robots: {
        category: "SEO — Crawlability",
        why: "robots.txt is the first thing search engine crawlers check — without it, there's no way to point them to a sitemap or control what gets crawled, which can slow down how fast new pages get indexed.",
      },
      sitemap: {
        category: "SEO — Crawlability",
        why: "A sitemap is how search engines reliably discover every page on a site, especially ones with no internal links pointing to them — without one referenced, some pages may never get indexed at all.",
      },
      "real-user-speed": {
        category: "Performance",
        why: "This is Google's own real-world Lighthouse performance score — a confirmed ranking factor, and also one of the top reasons visitors abandon a page before it even finishes loading.",
      },
      lcp: {
        category: "Performance — Core Web Vital",
        why: "Largest Contentful Paint is one of Google's three official Core Web Vitals and a direct ranking factor — it measures how long a visitor stares at a blank or half-loaded page before seeing real content.",
      },
      cls: {
        category: "User Experience — Core Web Vital",
        why: "Cumulative Layout Shift is a Core Web Vital and ranking factor that measures content jumping around mid-load — the classic case is a visitor going to tap a button and hitting an ad that just shifted into place instead.",
      },
      tbt: {
        category: "Performance",
        why: "Total Blocking Time approximates how long the page looks loaded but doesn't actually respond to clicks or taps — a page that feels frozen right after appearing drives visitors to leave, thinking it's broken.",
      },
      "real-a11y": {
        category: "Accessibility",
        why: "This is an automated scan for real accessibility barriers — color contrast, missing form labels, ARIA errors — that can lock out visitors using screen readers or other assistive tech, and carries real ADA legal exposure.",
      },
      "real-best-practices": {
        category: "Security & Modernity",
        why: "This flags outdated libraries, browser console errors, and other risky patterns Google's own Lighthouse audit considers below modern standard — often early warning signs of larger security or stability issues.",
      },
    };

    // Brand colors as RGB triples for jsPDF (which doesn't read CSS vars).
    const BRAND = {
      charcoal: [31, 33, 37] as [number, number, number],
      red: [239, 52, 47] as [number, number, number],
      amber: [239, 156, 47] as [number, number, number],
      teal: [76, 170, 201] as [number, number, number],
      gray: [90, 97, 105] as [number, number, number],
    };

    // Decodes the logo (WebP) via canvas so jsPDF — which only accepts
    // raster formats it can parse directly — gets a PNG data URL instead.
    async function loadLogoAsPngDataUrl(): Promise<string | null> {
      try {
        const img = new Image();
        img.crossOrigin = "anonymous";
        const loaded = new Promise<void>((resolve, reject) => {
          img.onload = () => resolve();
          img.onerror = () => reject(new Error("logo failed to load"));
        });
        img.src = "/images/logo-wordmark.webp";
        await loaded;
        const canvas = document.createElement("canvas");
        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        const ctx = canvas.getContext("2d");
        if (!ctx) return null;
        ctx.drawImage(img, 0, 0);
        return canvas.toDataURL("image/png");
      } catch {
        return null;
      }
    }

    async function downloadReport() {
      if (!lastAudit) return;
      downloadBtn.disabled = true;
      downloadBtn.textContent = "Preparing PDF...";

      // Fire-and-forget: lets Johnny know a lead downloaded their report.
      // Never awaited and errors are swallowed — a failed/slow notification
      // must never delay or break the actual PDF download.
      fetch("/api/audit-notify", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ url: lastAudit.url, score: lastAudit.score, grade: lastAudit.grade }),
      }).catch(() => {});

      try {
        const doc = new jsPDF({ unit: "mm", format: "a4" });
        const pageWidth = doc.internal.pageSize.getWidth();
        const pageHeight = doc.internal.pageSize.getHeight();
        const margin = 18;
        const contentWidth = pageWidth - margin * 2;

        // Header band
        doc.setFillColor(...BRAND.charcoal);
        doc.rect(0, 0, pageWidth, 28, "F");
        const logo = await loadLogoAsPngDataUrl();
        if (logo) {
          const logoW = 36;
          const logoH = logoW / 4; // matches the source's 4:1 aspect ratio
          doc.addImage(logo, "PNG", margin, 8, logoW, logoH);
        } else {
          doc.setTextColor(255, 255, 255);
          doc.setFont("helvetica", "bold");
          doc.setFontSize(16);
          doc.text("Retro Forge Studios", margin, 18);
        }
        doc.setTextColor(...BRAND.amber);
        doc.setFont("helvetica", "normal");
        doc.setFontSize(10);
        doc.text("Free Website Audit Report", pageWidth - margin, 18, { align: "right" });

        let y = 42;
        doc.setTextColor(...BRAND.charcoal);
        doc.setFont("helvetica", "bold");
        doc.setFontSize(18);
        doc.text("Website Audit Results", margin, y);

        y += 8;
        doc.setFont("helvetica", "normal");
        doc.setFontSize(10);
        doc.setTextColor(...BRAND.gray);
        const dateStr = new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
        doc.text(`${lastAudit.url}  —  ${dateStr}`, margin, y);

        // Score + grade
        y += 12;
        const gradeColor =
          lastAudit.grade === "A" || lastAudit.grade === "B"
            ? BRAND.teal
            : lastAudit.grade === "C"
              ? BRAND.amber
              : BRAND.red;
        doc.setDrawColor(...gradeColor);
        doc.setLineWidth(1.2);
        doc.circle(margin + 10, y + 4, 10, "S");
        doc.setTextColor(...gradeColor);
        doc.setFont("helvetica", "bold");
        doc.setFontSize(14);
        doc.text(lastAudit.grade, margin + 10, y + 8, { align: "center" });

        doc.setTextColor(...BRAND.charcoal);
        doc.setFontSize(12);
        doc.text(`${lastAudit.score}% overall`, margin + 26, y + 2);
        const passCount = lastAudit.checks.filter((c) => c.pass).length;
        doc.setFont("helvetica", "normal");
        doc.setFontSize(10);
        doc.setTextColor(...BRAND.gray);
        doc.text(`${passCount} of ${lastAudit.checks.length} checks passed`, margin + 26, y + 8);

        y += 18;

        // Legend — explains what the score/grade and marks actually mean,
        // so the report reads on its own without the live page next to it.
        doc.setFillColor(245, 246, 247);
        doc.setFont("helvetica", "normal");
        doc.setFontSize(9);
        const legendLines = doc.splitTextToSize(
          "This report checks 20+ technical, SEO, and performance signals that search engines and browsers use to judge a site's speed, trust, and findability. The grade above reflects the share that passed. A teal check means the site passes that signal; a red X means it fails and is likely costing real traffic, trust, or conversions — each failed check below explains which category it falls under, the actual mechanism by which it affects the score, and a plain-language recommendation for fixing it.",
          contentWidth - 12,
        ) as string[];
        const legendHeight = legendLines.length * 4.4 + 10;
        doc.roundedRect(margin, y, contentWidth, legendHeight, 2, 2, "F");
        doc.setTextColor(...BRAND.gray);
        doc.text(legendLines, margin + 6, y + 7);
        y += legendHeight + 12;

        doc.setDrawColor(220, 220, 220);
        doc.line(margin, y, pageWidth - margin, y);
        y += 10;

        // Checklist
        for (const check of lastAudit.checks) {
          // splitTextToSize measures wrap width using whatever font is
          // currently active on the doc — NOT the font the text is later
          // drawn with. Each block must set its real font/size before being
          // measured, or the computed line breaks won't match what actually
          // renders (bold text is wider, so it silently overflows the margin).
          doc.setFont("helvetica", "normal");
          doc.setFontSize(9.5);
          const detailLines = doc.splitTextToSize(check.detail, contentWidth - 8) as string[];

          const why = !check.pass ? WHY_IT_MATTERS[check.key] : undefined;
          let whyLines: string[] = [];
          if (why) {
            doc.setFont("helvetica", "normal");
            doc.setFontSize(9.5);
            whyLines = doc.splitTextToSize(`${why.category}: ${why.why}`, contentWidth - 8) as string[];
          }

          const recommendation = !check.pass ? RECOMMENDATIONS[check.key] : undefined;
          let recommendationLines: string[] = [];
          if (recommendation) {
            doc.setFont("helvetica", "bold");
            doc.setFontSize(9.5);
            recommendationLines = doc.splitTextToSize(`Recommendation: ${recommendation}`, contentWidth - 8) as string[];
          }

          const blockHeight =
            6 +
            detailLines.length * 4.6 +
            (whyLines.length ? whyLines.length * 4.6 + 2 : 0) +
            (recommendationLines.length ? recommendationLines.length * 4.6 + 2 : 0) +
            4;

          if (y + blockHeight > pageHeight - 24) {
            doc.addPage();
            y = margin;
          }

          // Filled circular badge behind the mark — much more prominent
          // than a bare glyph, and reads clearly even at a glance. The
          // check/X itself is drawn as vector lines rather than a Unicode
          // ✓/✗ character: jsPDF's built-in helvetica font has no glyph for
          // those code points, so doc.text() silently rendered nothing —
          // lines always render regardless of font.
          const markColor = check.pass ? BRAND.teal : BRAND.red;
          const markCX = margin + 3.2;
          const markCY = y - 2.1;
          doc.setFillColor(...markColor);
          doc.circle(markCX, markCY, 3.4, "F");
          doc.setDrawColor(255, 255, 255);
          doc.setLineWidth(0.7);
          if (check.pass) {
            doc.line(markCX - 1.6, markCY, markCX - 0.4, markCY + 1.3);
            doc.line(markCX - 0.4, markCY + 1.3, markCX + 1.8, markCY - 1.5);
          } else {
            doc.line(markCX - 1.5, markCY - 1.5, markCX + 1.5, markCY + 1.5);
            doc.line(markCX - 1.5, markCY + 1.5, markCX + 1.5, markCY - 1.5);
          }

          doc.setTextColor(...BRAND.charcoal);
          doc.setFontSize(11);
          doc.text(check.label, margin + 10, y);

          y += 5.5;
          doc.setFont("helvetica", "normal");
          doc.setFontSize(9.5);
          doc.setTextColor(...BRAND.gray);
          doc.text(detailLines, margin + 10, y);
          y += detailLines.length * 4.6;

          if (whyLines.length) {
            y += 2;
            doc.setFont("helvetica", "normal");
            doc.setFontSize(9.5);
            doc.setTextColor(...BRAND.charcoal);
            doc.text(whyLines, margin + 10, y);
            y += whyLines.length * 4.6;
          }

          if (recommendationLines.length) {
            y += 2;
            doc.setFont("helvetica", "bold");
            doc.setFontSize(9.5);
            doc.setTextColor(...BRAND.red);
            doc.text(recommendationLines, margin + 10, y);
            y += recommendationLines.length * 4.6;
          }

          y += 5;
        }

        // Footer CTA on the last page
        if (y + 36 > pageHeight - 10) {
          doc.addPage();
          y = margin;
        }
        y = Math.max(y, pageHeight - 46);
        doc.setDrawColor(...BRAND.amber);
        doc.setFillColor(...BRAND.amber);
        doc.roundedRect(margin, y, contentWidth, 30, 3, 3, "F");
        doc.setTextColor(...BRAND.charcoal);
        doc.setFont("helvetica", "bold");
        doc.setFontSize(11);
        doc.text("Want these fixed?", margin + 6, y + 9);
        doc.setFont("helvetica", "normal");
        doc.setFontSize(9.5);
        doc.text("Book a free call — retroforgestudios.com/contact", margin + 6, y + 16);
        doc.setFont("helvetica", "bold");
        doc.text(CONTACT_EMAIL, margin + 6, y + 23);

        const hostname = (() => {
          try {
            return new URL(lastAudit.url).hostname.replace(/\W+/g, "-");
          } catch {
            return "site";
          }
        })();
        doc.save(`website-audit-${hostname}.pdf`);
      } finally {
        downloadBtn.disabled = false;
        downloadBtn.textContent = "Download My Results";
      }
    }

    downloadBtn.addEventListener("click", () => {
      downloadReport();
    });

    function buildSummary(checks: CheckResult[]) {
      const failed = checks.filter((c) => !c.pass);
      if (failed.length === 0) {
        return "This site is technically solid — but passing an automated checklist isn't the same as turning visitors into paying customers. That's the part a second set of expert eyes actually helps with.";
      }

      const critical = failed.some((c) => c.key === "indexable" || c.key === "https");
      const topIssues = failed.slice(0, 3).map((c) => c.label.toLowerCase()).join(", ");

      if (critical) {
        return `This site has at least one serious issue (${topIssues}) that can actively block customers or Google from finding it. These aren't quick DIY toggle-flips — fixing them properly, without breaking anything else, is exactly the kind of work I do every day.`;
      }
      if (failed.length >= 5) {
        return `${failed.length} of these checks failed. Individually small, but together they quietly cost real traffic, trust, and customers over time. A short call is the fastest way to turn this list into a fixed, working site.`;
      }
      return `A handful of real issues here (${topIssues}) are quietly costing this site traffic and trust. They're genuinely fixable fast — a short call is enough to map out exactly what to prioritize first.`;
    }

    const ringColor: Record<string, string> = {
      A: "border-teal",
      B: "border-teal",
      C: "border-amber",
      D: "border-red",
      F: "border-red",
    };

    function renderCheck(check: CheckResult) {
      const li = document.createElement("li");
      li.className = "flex gap-3";

      // Built with DOM methods + textContent (not innerHTML) so a check's
      // label/detail — which can include raw text pulled from the audited
      // site itself (its title, its meta description, etc.) — is never
      // parsed as markup. That avoids both the "<h1> found" text rendering
      // as an actual empty <h1> tag, and a real script-injection risk from
      // an untrusted third-party page's content.
      const iconTemplate = document.createElement("template");
      iconTemplate.innerHTML = check.pass
        ? `<svg viewBox="0 0 24 24" class="mt-0.5 h-5 w-5 flex-none text-teal" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" /></svg>`
        : `<svg viewBox="0 0 24 24" class="mt-0.5 h-5 w-5 flex-none text-red" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" stroke-linejoin="round" /></svg>`;
      li.appendChild(iconTemplate.content.firstElementChild as Node);

      const textWrap = document.createElement("div");

      const labelEl = document.createElement("p");
      labelEl.className = "font-semibold text-white";
      labelEl.textContent = check.label;

      const detailEl = document.createElement("p");
      detailEl.className = "mt-0.5 text-sm text-teal/80";
      detailEl.textContent = check.detail;

      textWrap.append(labelEl, detailEl);

      // Failed checks get an extra "why this affects the score" block —
      // what category it falls under and the actual mechanism (ranking
      // factor, browser-enforced penalty, accessibility exposure, etc.),
      // not just a bare pass/fail.
      if (!check.pass) {
        const why = WHY_IT_MATTERS[check.key];
        if (why) {
          const whyEl = document.createElement("p");
          whyEl.className = "mt-2 text-sm text-gray-300";

          const categoryEl = document.createElement("span");
          categoryEl.className = "mr-1.5 inline-block rounded bg-red/20 px-1.5 py-0.5 text-xs font-bold uppercase tracking-wide text-red";
          categoryEl.textContent = why.category;

          whyEl.appendChild(categoryEl);
          whyEl.appendChild(document.createTextNode(why.why));
          textWrap.appendChild(whyEl);
        }

        const recommendation = RECOMMENDATIONS[check.key];
        if (recommendation) {
          const recEl = document.createElement("p");
          recEl.className = "mt-1.5 text-sm font-semibold text-amber";
          recEl.textContent = `Recommendation: ${recommendation}`;
          textWrap.appendChild(recEl);
        }
      }

      li.appendChild(textWrap);
      return li;
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorBox.hidden = true;
      results.hidden = true;
      submitBtn.disabled = true;
      submitBtn.textContent = "Running audit...";

      // The on-page checks resolve almost instantly, but the real-world
      // performance pass can take a while — let people know so it doesn't
      // feel stuck if it runs long.
      const slowNotice = setTimeout(() => {
        submitBtn.textContent = "Analyzing performance... this can take up to a minute";
      }, 2500);

      try {
        const res = await fetch("/api/audit", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url: urlInput.value }),
        });
        const data = await res.json();

        if (!data.ok) {
          errorBox.textContent = data.error || "Something went wrong. Please try again.";
          errorBox.hidden = false;
          return;
        }

        scoreEl.textContent = `${data.score}%`;
        gradeEl.textContent = data.grade;
        countEl.textContent = `${data.checks.filter((c: { pass: boolean }) => c.pass).length} of ${data.checks.length}`;

        scoreRing.className = `flex h-20 w-20 flex-none items-center justify-center rounded-full border-4 ${ringColor[data.grade] || "border-teal"}`;

        checklist.innerHTML = "";
        data.checks.forEach((check: CheckResult) => {
          checklist.appendChild(renderCheck(check));
        });

        summaryText.textContent = buildSummary(data.checks);

        lastAudit = { url: data.url, score: data.score, grade: data.grade, checks: data.checks };

        results.hidden = false;
      } catch {
        errorBox.textContent = "Something went wrong. Please try again.";
        errorBox.hidden = false;
      } finally {
        clearTimeout(slowNotice);
        submitBtn.disabled = false;
        submitBtn.textContent = "Run Audit";
      }
    });
  </script>
</BaseLayout>
