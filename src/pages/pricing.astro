---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTABanner from "../components/sections/CTABanner.astro";
import Button from "../components/ui/Button.astro";
import CrownBadge from "../components/badges/CrownBadge.astro";
import PageHero from "../components/sections/PageHero.astro";
import { LAUNCH_BUILD, LAUNCH_BUILD_FAQS, PRICING_FAQ, PRICING_TIERS } from "../data/site";
---

<BaseLayout
  title="Pricing"
  description="Straightforward pricing for website design, content, brand strategy, and social media management — no surprises."
>
  <PageHero
    eyebrow="pricing"
    heading="Straightforward pricing, no surprises."
    subhead="Pick a package that fits where your business is now, or let's build something custom. Either way, you'll know exactly what you're getting."
  />

  <!-- Launch Build: one-time website project -->
  <section class="px-4 py-10 sm:px-6">
    <div class="mx-auto max-w-3xl rounded-xl border border-red bg-[#2c2f34] p-8 sm:p-10">
      <p class="text-marker text-lg text-amber">{LAUNCH_BUILD.name}</p>
      <h2 class="mt-2 text-2xl text-white sm:text-3xl">{LAUNCH_BUILD.tagline}</h2>
      <p class="mt-3 text-gray-300">{LAUNCH_BUILD.description}</p>
      <ul class="mt-6 space-y-2">
        {LAUNCH_BUILD.features.map((feature) => (
          <li class="flex gap-2 text-sm text-gray-300">
            <span class="text-teal">&#8226;</span>
            {feature}
          </li>
        ))}
      </ul>
      <p class="mt-4 text-xs text-gray-500">{LAUNCH_BUILD.footnote}</p>
      <Button href="/contact" class="mt-8 w-full sm:w-auto">{LAUNCH_BUILD.cta}</Button>
    </div>
  </section>

  <!-- Launch Build FAQ -->
  <section class="bg-band px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-center text-2xl text-gray-900">Launch Build questions</h2>
      <div class="mt-8 space-y-6">
        {LAUNCH_BUILD_FAQS.map((item) => (
          <div>
            <p class="font-semibold text-gray-900">{item.q}</p>
            <p class="mt-1 text-sm text-gray-700">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ongoing monthly services -->
  <section class="px-4 pt-16 text-center sm:px-6">
    <p class="text-marker text-lg text-teal-deep">ongoing services</p>
    <h2 class="mt-2 text-2xl text-gray-900 sm:text-3xl">Need help keeping it growing?</h2>
    <p class="mx-auto mt-3 max-w-xl text-gray-700">
      Once your site's live, these monthly packages keep the momentum going — content, brand, and social all handled.
    </p>
  </section>

  <section class="bg-band px-4 py-10 sm:px-6">
    <div class="mx-auto grid max-w-content grid-cols-1 gap-6 sm:grid-cols-3">
      {PRICING_TIERS.map((tier) => (
        <div
          class:list={[
            "relative rounded-xl border p-8",
            tier.featured ? "border-red bg-[#2c2f34]" : "border-surface bg-[#1f2125]",
          ]}
        >
          {tier.featured && <CrownBadge class="absolute -top-3 right-6" />}
          <h3 class="text-2xl text-white">{tier.name}</h3>
          <p class="mt-1 text-sm text-gray-400">{tier.tagline}</p>
          <p class="mt-6 text-3xl text-amber">{tier.price}</p>
          <ul class="mt-6 space-y-2">
            {tier.features.map((feature) => (
              <li class="flex gap-2 text-sm text-gray-300">
                <span class="text-teal">&#8226;</span>
                {feature}
              </li>
            ))}
          </ul>
          <Button href={tier.href} target="_blank" variant={tier.featured ? "primary" : "secondary"} class="mt-8 w-full">
            {tier.cta}
          </Button>
        </div>
      ))}
    </div>
    <p class="mx-auto mt-8 max-w-2xl text-center text-sm text-gray-700">
      Ongoing work like social management and content is billed monthly. One-off projects — brand refreshes, website
      copy, campaign sprints — are quoted per project.
    </p>
  </section>

  <section class="px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl text-gray-900">Need something different?</h2>
      <p class="mt-3 text-gray-700">
        One-off project, a specific campaign, or a mix of services that doesn't fit a neat tier — let's talk about a
        custom scope.{" "}
        <a href="/contact" class="font-semibold text-teal-deep hover:underline">Get in touch &rarr;</a>
      </p>
    </div>
  </section>

  <section class="bg-band px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-2xl rounded-xl border border-amber/40 bg-amber/15 p-8 text-center">
      <h2 class="text-2xl text-gray-900">Founding client rate</h2>
      <p class="mt-3 text-gray-700">
        I'm currently taking on a limited number of founding clients at a reduced rate, in exchange for a
        testimonial and permission to feature the results as a case study. A straightforward trade: you get a lower
        price while I build my portfolio.
      </p>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-center text-2xl text-gray-900">FAQ</h2>
      <div class="mt-8 space-y-6">
        {PRICING_FAQ.map((item) => (
          <div>
            <p class="font-semibold text-gray-900">{item.q}</p>
            <p class="mt-1 text-sm text-gray-700">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Still deciding what fits?"
    subtext="Let's talk it through — no pressure, no obligation."
    buttonLabel="Book a free call"
  />
</BaseLayout>
