---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import SocialIcon from "../components/ui/SocialIcon.astro";
import { SITE, SOCIAL_LINKS } from "../data/site";

const fieldClass =
  "mt-1 w-full rounded-md border border-gray-300 px-3 py-2 focus:border-teal-deep focus:outline-none focus:ring-1 focus:ring-teal-deep";
---

<BaseLayout
  title="Contact"
  description={`Get in touch with Retro Forge Studios — based in ${SITE.city}, ${SITE.region}, serving small businesses across Nebraska & Iowa.`}
>
  <PageHero
    eyebrow="get in touch"
    heading="Send us a message"
    subhead="We'd love to hear from you — fill out the form below and we'll get back to you soon."
  />

  <section class="px-4 py-20 sm:px-6">
    <div class="mx-auto grid max-w-4xl gap-12 md:grid-cols-2">
      <!-- Contact details -->
      <div class="space-y-6">
        <div>
          <p class="text-marker text-lg text-teal-deep">Email</p>
          <a href={`mailto:${SITE.email}`} class="mt-1 block text-lg text-gray-900 hover:text-teal-deep">
            {SITE.email}
          </a>
        </div>

        <div>
          <p class="text-marker text-lg text-teal-deep">Area</p>
          <p class="mt-1 text-lg text-gray-900">
            {SITE.city}, {SITE.region} — serving small businesses across Nebraska & Iowa
          </p>
        </div>

        <div>
          <p class="text-marker text-lg text-teal-deep">Prefer to talk it through?</p>
          <a href="/chat-with-johnny" class="mt-1 block text-lg text-gray-900 hover:text-teal-deep">
            Book a free call &rarr;
          </a>
        </div>

        <div>
          <p class="text-marker text-lg text-teal-deep">Follow us</p>
          <div class="mt-3 flex gap-4">
            {SOCIAL_LINKS.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="text-gray-500 transition-colors hover:text-teal-deep"
              >
                <SocialIcon label={social.label} class="h-5 w-5" />
              </a>
            ))}
          </div>
        </div>

        <p class="text-sm text-gray-500">
          I read every message personally — you'll hear back from me, not a bot.
        </p>
      </div>

      <!-- Contact form -->
      <div>
        <!-- Success message (revealed after a successful send) -->
        <div id="form-success" hidden class="rounded-md border border-green-300 bg-green-50 p-4 text-green-800">
          <p class="font-semibold">Thanks — your message has been sent!</p>
          <p class="mt-1 text-sm">We'll get back to you as soon as we can.</p>
        </div>

        <!-- Error message (revealed if the send failed) -->
        <div id="form-error" hidden class="rounded-md border border-red-300 bg-red-50 p-4 text-red-800">
          <p class="font-semibold">Something went wrong.</p>
          <p class="mt-1 text-sm">
            Please try again, or email us directly at <a href={`mailto:${SITE.email}`} class="underline">{SITE.email}</a>.
          </p>
        </div>

        <form id="contact-form" action="/api/contact" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700">Name</label>
            <input type="text" id="name" name="name" required class={fieldClass} />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700">Email</label>
            <input type="email" id="email" name="email" required class={fieldClass} />
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700">Message</label>
            <textarea id="message" name="message" rows="5" required class={fieldClass}></textarea>
          </div>

          <!-- Honeypot: bots fill this, humans don't -->
          <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <button
            type="submit"
            id="contact-submit"
            class="flex w-full items-center justify-center gap-2 rounded-md bg-red px-6 py-3 font-bold text-white transition duration-200 hover:bg-red/90 disabled:cursor-not-allowed disabled:opacity-70"
          >
            <svg
              id="contact-submit-spinner"
              hidden
              class="h-4 w-4 animate-spin text-white"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8V0C5.373 0 0 5.373 0 12h4z" />
            </svg>
            <span id="contact-submit-label">Send message</span>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Service area map -->
  <section class="px-4 pb-20 sm:px-6">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-center text-2xl text-gray-900">Where we work</h2>
      <p class="mx-auto mt-2 max-w-xl text-center text-gray-600">
        Based in {SITE.city}, {SITE.region} — serving small businesses across Nebraska & Iowa.
      </p>
      <div class="mt-8 overflow-hidden rounded-xl border border-gray-200 shadow-sm">
        <iframe
          src="https://www.google.com/maps?q=Omaha,+NE&z=9&output=embed"
          title="Map showing the Retro Forge Studios service area around Omaha, NE"
          class="h-[320px] w-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <script is:inline>
    const params = new URLSearchParams(location.search);
    if (params.has("sent")) {
      document.getElementById("form-success")?.removeAttribute("hidden");
      document.getElementById("contact-form")?.setAttribute("hidden", "");
    } else if (params.has("error")) {
      document.getElementById("form-error")?.removeAttribute("hidden");
    }

    // Give the submit button immediate visual feedback so it's clear the
    // click registered — the form does a full-page POST + redirect, so
    // there's otherwise a beat of silence while the request round-trips.
    document.getElementById("contact-form")?.addEventListener("submit", (e) => {
      const button = document.getElementById("contact-submit");
      if (!button || button.disabled) return;
      button.disabled = true;
      document.getElementById("contact-submit-spinner")?.removeAttribute("hidden");
      const label = document.getElementById("contact-submit-label");
      if (label) label.textContent = "Sending...";
    });
  </script>
</BaseLayout>
