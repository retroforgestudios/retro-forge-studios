---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import CTABanner from "../components/sections/CTABanner.astro";
import PageHero from "../components/sections/PageHero.astro";
import { PROCESS_STEPS, SERVICES } from "../data/site";
---

<BaseLayout
  title="Services"
  description="Content creation, brand strategy & SEO, and social media management for Nebraska & Iowa businesses."
>
  <PageHero
    eyebrow="what i do"
    heading="Three ways to grow, one local studio."
    subhead="Whether you need a one-time push or ongoing monthly support, I act as a fast, tech-forward extension of your team — not another vendor to manage."
  />

  <!-- Service teaser cards -->
  <section class="px-4 py-16 sm:px-6">
    <div class="mx-auto grid max-w-content grid-cols-1 gap-6 sm:grid-cols-3">
      {SERVICES.map((service) => (
        <a
          href={`/services/${service.slug}`}
          class="flex flex-col rounded-lg border border-surface bg-[#2c2f34] p-6 text-center transition-colors hover:bg-[#34373d]"
        >
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-charcoal text-amber">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7">
              <path d={service.icon} />
            </svg>
          </div>
          <h3 class="mt-4 text-lg text-white">{service.name}</h3>
          <p class="mt-2 flex-1 text-sm text-gray-300">{service.teaser}</p>
          <span class="mt-4 text-sm font-semibold text-teal">Learn more &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Marketing dashboard banner -->
  <section class="bg-band px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <SectionHeader onLight eyebrow="real tools, real data" heading="Strategy backed by dashboards, not guesswork" />
      <img
        src="/images/marketing-dashboard.webp"
        alt="A HubSpot marketing dashboard showing visits, contacts, and customer metrics"
        class="mx-auto mt-8 w-full max-w-3xl rounded-xl border border-surface"
        width="1080"
        height="450"
        loading="lazy"
      />
    </div>
  </section>

  <!-- Process strip -->
  <section class="bg-band px-4 py-20 sm:px-6">
    <SectionHeader onLight eyebrow="the process" heading="How a project actually runs" />
    <div class="mx-auto mt-10 max-w-2xl space-y-8">
      {PROCESS_STEPS.map((step, i) => (
        <div class="flex gap-6">
          <div class="flex h-14 w-14 flex-none items-center justify-center rounded-full bg-amber text-xl font-bold text-charcoal">
            {`0${i + 1}`}
          </div>
          <div>
            <h3 class="text-xl text-gray-900">{step.name}</h3>
            <p class="mt-1 text-gray-700">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
    <p class="mt-8 text-center">
      <a href="/how-i-work" class="font-semibold text-teal-deep hover:underline">Want the full breakdown? See how I work &rarr;</a>
    </p>
  </section>

  <CTABanner
    heading="Not sure what you need?"
    subtext="Let's talk through your goals and figure out the right mix — no pressure, no jargon."
    buttonLabel="Book a free call"
  />
</BaseLayout>
