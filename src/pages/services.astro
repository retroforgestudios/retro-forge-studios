---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import CTABanner from "../components/sections/CTABanner.astro";
import PageHero from "../components/sections/PageHero.astro";
import { PROCESS_STEPS, SERVICES } from "../data/site";
---

<BaseLayout
  title="Services"
  description="Content creation, brand strategy & SEO, and social media management for Nebraska & Iowa businesses."
>
  <PageHero
    eyebrow="what i do"
    heading="Three ways to grow, one local studio."
    subhead="Whether you need a one-time push or ongoing monthly support, I act as a fast, tech-forward extension of your team — not another vendor to manage."
  />

  {SERVICES.map((service, i) => (
    <section id={service.slug} class:list={["px-4 py-16 sm:px-6", i % 2 === 1 && "bg-band"]}>
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl text-white sm:text-4xl">{service.heading}</h2>

        <div class="mt-8 grid gap-8 sm:grid-cols-2">
          <div>
            <p class="text-marker text-amber">included</p>
            <ul class="mt-3 space-y-2 text-gray-300">
              {service.included.map((item) => (
                <li class="flex gap-2">
                  <span class="text-teal">&#8226;</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="space-y-4">
            {service.statCallout && (
              <p class="rounded-md border border-amber/40 bg-amber/10 p-4 text-sm text-amber">
                {service.statCallout}
              </p>
            )}
            <p class="text-sm text-gray-400">
              <span class="font-semibold text-white">Who it's for: </span>
              {service.who}
            </p>
            <p class="text-sm text-gray-400">
              <span class="font-semibold text-white">Outcome: </span>
              {service.outcome}
            </p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Process strip -->
  <section class="bg-band px-4 py-20 sm:px-6">
    <SectionHeader eyebrow="the process" heading="How a project actually runs" />
    <div class="mx-auto mt-10 grid max-w-content grid-cols-1 gap-4 sm:grid-cols-4">
      {PROCESS_STEPS.map((step) => (
        <div class="rounded-lg border border-surface bg-[#2c2f34] p-4 text-center">
          <p class="font-bold text-teal">{step.name}</p>
        </div>
      ))}
    </div>
    <p class="mt-8 text-center">
      <a href="/how-i-work" class="font-semibold text-teal hover:underline">Want the full breakdown? See how I work &rarr;</a>
    </p>
  </section>

  <section class="px-4 py-20 sm:px-6">
    <CTABanner
      heading="Not sure what you need?"
      subtext="Let's talk through your goals and figure out the right mix — no pressure, no jargon."
      buttonLabel="Book a free call"
    />
  </section>
</BaseLayout>
