---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import CTABanner from "../components/sections/CTABanner.astro";
import PageHero from "../components/sections/PageHero.astro";
import { PROCESS_STEPS, SERVICES } from "../data/site";

const SERVICE_ICONS: Record<string, string> = {
  "content-creation":
    "M7 4h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zM9 12h6M9 16h6",
  "brand-strategy-seo":
    "M11 18a7 7 0 1 0 0-14 7 7 0 0 0 0 14zm0-3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7zM20 20l-4.35-4.35",
  "social-media-management":
    "M18 8a3 3 0 1 0-2.83-4H15a3 3 0 1 0 0 6 2.97 2.97 0 0 0 1.74-.56l-5.49 3.2a3 3 0 1 0 0 2.72l5.49 3.2A2.97 2.97 0 0 0 15 17a3 3 0 1 0 2.83-4",
};
---

<BaseLayout
  title="Services"
  description="Content creation, brand strategy & SEO, and social media management for Nebraska & Iowa businesses."
>
  <PageHero
    eyebrow="what i do"
    heading="Three ways to grow, one local studio."
    subhead="Whether you need a one-time push or ongoing monthly support, I act as a fast, tech-forward extension of your team — not another vendor to manage."
  />

  <!-- Service teaser cards -->
  <section class="px-4 py-16 sm:px-6">
    <div class="mx-auto grid max-w-content grid-cols-1 gap-6 sm:grid-cols-3">
      {SERVICES.map((service) => (
        <a
          href={`#${service.slug}`}
          class="rounded-lg border border-surface bg-[#2c2f34] p-6 text-center transition-colors hover:bg-[#34373d]"
        >
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-charcoal text-amber">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7">
              <path d={SERVICE_ICONS[service.slug]} />
            </svg>
          </div>
          <h3 class="mt-4 text-lg text-white">{service.name}</h3>
          <p class="mt-2 text-sm text-gray-300">{service.teaser}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Marketing dashboard banner -->
  <section class="bg-band px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <SectionHeader onLight eyebrow="real tools, real data" heading="Strategy backed by dashboards, not guesswork" />
      <img
        src="/images/marketing-dashboard.webp"
        alt="A HubSpot marketing dashboard showing visits, contacts, and customer metrics"
        class="mx-auto mt-8 w-full max-w-3xl rounded-xl border border-surface"
        width="1080"
        height="450"
        loading="lazy"
      />
    </div>
  </section>

  {SERVICES.map((service) => (
    <section id={service.slug} class="px-4 py-16 sm:px-6">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl text-gray-900 sm:text-4xl">{service.heading}</h2>

        <div class="mt-8 grid gap-8 sm:grid-cols-2">
          <div>
            <p class="text-marker text-amber-deep">included</p>
            <ul class="mt-3 space-y-2 text-gray-700">
              {service.included.map((item) => (
                <li class="flex gap-2">
                  <span class="text-teal-deep">&#8226;</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="space-y-4">
            {service.statCallout && (
              <p class="rounded-md border border-amber/40 bg-amber/15 p-4 text-sm text-amber-deep">
                {service.statCallout}
              </p>
            )}
            <p class="text-sm text-gray-600">
              <span class="font-semibold text-gray-900">Who it's for: </span>
              {service.who}
            </p>
            <p class="text-sm text-gray-600">
              <span class="font-semibold text-gray-900">Outcome: </span>
              {service.outcome}
            </p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Process strip -->
  <section class="bg-band px-4 py-20 sm:px-6">
    <SectionHeader onLight eyebrow="the process" heading="How a project actually runs" />
    <div class="mx-auto mt-10 max-w-2xl space-y-8">
      {PROCESS_STEPS.map((step, i) => (
        <div class="flex gap-6">
          <div class="flex h-14 w-14 flex-none items-center justify-center rounded-full bg-amber text-xl font-bold text-charcoal">
            {`0${i + 1}`}
          </div>
          <div>
            <h3 class="text-xl text-gray-900">{step.name}</h3>
            <p class="mt-1 text-gray-700">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
    <p class="mt-8 text-center">
      <a href="/how-i-work" class="font-semibold text-teal-deep hover:underline">Want the full breakdown? See how I work &rarr;</a>
    </p>
  </section>

  <CTABanner
    heading="Not sure what you need?"
    subtext="Let's talk through your goals and figure out the right mix — no pressure, no jargon."
    buttonLabel="Book a free call"
  />
</BaseLayout>
